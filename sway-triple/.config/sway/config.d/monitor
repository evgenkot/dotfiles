# Triple-monitor layout: laptop panel plus two external DisplayPort monitors.
output eDP-1 {
    resolution 1920x1200
    position 0 0
    scale 1
}

output DP-6 {
    resolution 1920x1080
    position 1920 0
    scale 1
}

output DP-5 {
    resolution 1920x1080
    position 3840 0
    scale 1
}

# Disable laptop panel when the lid closes, restore it when the lid opens.
bindswitch --reload --locked lid:on output eDP-1 disable
bindswitch --reload --locked lid:off output eDP-1 enable, output eDP-1 resolution 1920x1200 position 0 0 scale 1
