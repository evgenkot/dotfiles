# Sway config aligned with the Hyprland config in ../hyprland.
# Read `man 5 sway` for a complete reference.

### Variables
set $mod Mod4
set $left h
set $down j
set $up k
set $right l

set $term alacritty
set $fileManager xdg-open "$HOME"
set $menu wofi --show run
set $browser xdg-open about:blank
set $lock swaylock -f

### Look and feel
gaps inner 0
gaps outer 0
default_border pixel 1
default_floating_border pixel 1
smart_borders on
focus_follows_mouse yes
mouse_warping container
floating_modifier $mod normal

### Idle
exec swayidle -w \
    timeout 300 'swaylock -f' \
    timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
    before-sleep 'swaylock -f'

### Key bindings
bindsym $mod+Return exec $term
bindsym $mod+Shift+Return exec $browser
bindsym $mod+c kill
bindsym $mod+d exec $menu
bindsym $mod+Shift+x exit
bindsym $mod+x exec $lock
bindsym $mod+e exec $fileManager
bindsym $mod+Shift+n floating toggle
bindsym $mod+b exec killall -SIGUSR1 waybar
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+c reload

# Screenshots
bindsym $mod+Shift+s exec 'mkdir -p ~/Pictures/Screenshots; filename=~/Pictures/Screenshots/Screenshot-$(date +"%Y-%m-%d-%H:%M:%S").png; grim -g "$(slurp)" "$filename" && wl-copy < "$filename"'
bindsym Mod1+Print exec 'mkdir -p ~/Pictures/Screenshots; filename=~/Pictures/Screenshots/Screenshot-$(date +"%Y-%m-%d-%H:%M:%S").png; geometry=$(swaymsg -t get_tree | jq -r ".. | objects | select(.focused? == true) | .rect | \"\(.x),\(.y) \(.width)x\(.height)\""); grim -g "$geometry" "$filename" && wl-copy < "$filename"'
bindsym Print exec 'mkdir -p ~/Pictures/Screenshots; filename=~/Pictures/Screenshots/Screenshot-$(date +"%Y-%m-%d-%H:%M:%S").png; grim "$filename" && wl-copy < "$filename"'

# Move focus with mainMod + arrow keys
bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

# Vim keys
bindsym $mod+$left focus left
bindsym $mod+$right focus right
bindsym $mod+$up focus up
bindsym $mod+$down focus down

# Move windows with mainMod + Shift + arrow keys
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Down move down

# Vim keys
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$down move down

# Resize with mainMod + Alt + arrow keys
bindsym $mod+Mod1+Right resize grow width 100px
bindsym $mod+Mod1+Left resize shrink width 100px
bindsym $mod+Mod1+Up resize shrink height 100px
bindsym $mod+Mod1+Down resize grow height 100px

# Resize with Vim keys
bindsym $mod+Mod1+$right resize grow width 100px
bindsym $mod+Mod1+$left resize shrink width 100px
bindsym $mod+Mod1+$up resize shrink height 100px
bindsym $mod+Mod1+$down resize grow height 100px

# Switch workspaces with mainMod + [0-9]
bindsym --inhibited $mod+1 workspace number 1
bindsym --inhibited $mod+2 workspace number 2
bindsym --inhibited $mod+3 workspace number 3
bindsym --inhibited $mod+4 workspace number 4
bindsym --inhibited $mod+5 workspace number 5
bindsym --inhibited $mod+6 workspace number 6
bindsym --inhibited $mod+7 workspace number 7
bindsym --inhibited $mod+8 workspace number 8
bindsym --inhibited $mod+9 workspace number 9
bindsym --inhibited $mod+0 workspace number 10

# Move active window to a workspace with mainMod + Shift + [0-9]
bindsym --inhibited $mod+Shift+1 move container to workspace number 1
bindsym --inhibited $mod+Shift+2 move container to workspace number 2
bindsym --inhibited $mod+Shift+3 move container to workspace number 3
bindsym --inhibited $mod+Shift+4 move container to workspace number 4
bindsym --inhibited $mod+Shift+5 move container to workspace number 5
bindsym --inhibited $mod+Shift+6 move container to workspace number 6
bindsym --inhibited $mod+Shift+7 move container to workspace number 7
bindsym --inhibited $mod+Shift+8 move container to workspace number 8
bindsym --inhibited $mod+Shift+9 move container to workspace number 9
bindsym --inhibited $mod+Shift+0 move container to workspace number 10

# Special workspace equivalent. Workspace 11 keeps normal tiling/fullscreen behavior.
bindsym --inhibited $mod+o exec ~/.config/sway/scripts/toggle-magic-workspace
bindsym --inhibited $mod+Shift+o move container to workspace 11:m

# Scroll through workspaces with mainMod + scroll
bindsym --whole-window $mod+button5 workspace next_on_output
bindsym --whole-window $mod+button4 workspace prev_on_output

# Laptop multimedia keys for volume and LCD brightness
bindsym --locked XF86AudioRaiseVolume exec wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 5%+
bindsym --locked XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym --locked XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym --locked XF86MonBrightnessUp exec brightnessctl s 10%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl s 10%-

bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioPause exec playerctl play-pause
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioPrev exec playerctl previous

include ~/.config/sway/config.d/*
include /etc/sway/config.d/*
